{
  "cases": [
    {
      "name": "canonical identity is exhaustive",
      "literal": true,
      "serialized": "source=SourcePart;target=SourcePart;map=root:root,header:header,readout:readout",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "header", "readout"],
      "requireIdentity": true,
      "expectedCodes": []
    },
    {
      "name": "embedded adapter suppresses only its root",
      "literal": true,
      "serialized": "source=SourcePart;target=TargetPart;map=root:null,header:pickerHeader,readout:pickerReadout",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "ownerSlots": ["root", "pickerPanel"],
      "expectedCodes": []
    },
    {
      "name": "nonliteral adapter is rejected",
      "literal": false,
      "serialized": "source=SourcePart;target=TargetPart;map=root:null,header:pickerHeader,readout:pickerReadout",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "ownerSlots": ["root", "pickerPanel"],
      "expectedCodes": ["nonliteral"]
    },
    {
      "name": "missing source and target are rejected",
      "literal": true,
      "serialized": "source=SourcePart;target=TargetPart;map=root:null,header:pickerHeader",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "ownerSlots": ["root", "pickerPanel"],
      "expectedCodes": ["missing-source", "missing-target"]
    },
    {
      "name": "unknown source is rejected",
      "literal": true,
      "serialized": "source=SourcePart;target=TargetPart;map=root:null,header:pickerHeader,readout:pickerReadout,bogus:root",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "ownerSlots": ["root", "pickerPanel"],
      "expectedCodes": ["duplicate-target", "unknown-source"]
    },
    {
      "name": "unknown target is rejected",
      "literal": true,
      "serialized": "source=SourcePart;target=TargetPart;map=root:null,header:unknown,readout:pickerReadout",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "ownerSlots": ["root", "pickerPanel"],
      "expectedCodes": ["missing-target", "unknown-target"]
    },
    {
      "name": "duplicate source and target are rejected",
      "literal": true,
      "serialized": "source=SourcePart;target=TargetPart;map=root:null,header:pickerHeader,header:pickerReadout,readout:pickerReadout",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "ownerSlots": ["root", "pickerPanel"],
      "expectedCodes": ["duplicate-source", "duplicate-target"]
    },
    {
      "name": "null is reserved for the child root",
      "literal": true,
      "serialized": "source=SourcePart;target=TargetPart;map=root:null,header:null,readout:pickerReadout",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "ownerSlots": ["root", "pickerPanel"],
      "expectedCodes": ["invalid-null", "missing-target"]
    },
    {
      "name": "canonical declaration cannot rename parts",
      "literal": true,
      "serialized": "source=SourcePart;target=SourcePart;map=root:root,header:readout,readout:header",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "header", "readout"],
      "requireIdentity": true,
      "expectedCodes": ["nonidentity-canonical"]
    },
    {
      "name": "invalid grammar is rejected",
      "literal": true,
      "serialized": "SourcePart -> TargetPart",
      "sourceParts": ["root", "header", "readout"],
      "targetParts": ["root", "pickerPanel", "pickerHeader", "pickerReadout"],
      "expectedCodes": ["invalid-syntax"]
    }
  ]
}
