{
  "name": "hell-ui-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "start": "pnpm --filter hell-docs start",
    "build": "pnpm run build:lib && pnpm run build:docs",
    "build:lib": "pnpm --filter hell-ui build",
    "build:docs": "pnpm --filter hell-docs build",
    "watch": "pnpm --filter hell-ui watch",
    "test:unit": "pnpm --filter hell-ui exec ng test hell --watch=false --progress=false --runner-config ../../vitest.config.ts",
    "test:coverage": "pnpm --filter hell-ui exec ng test hell --watch=false --progress=false --runner-config ../../vitest.config.ts --coverage",
    "test": "pnpm run test:unit && pnpm run test:dead-code && pnpm run test:architecture",
    "lint": "eslint .",
    "test:dead-code": "knip",
    "e2e": "playwright test",
    "generate:entrypoints": "node tools/generate-entrypoint-manifests.mjs",
    "test:architecture": "node tools/check-architecture.mjs",
    "test:api-report": "node tools/check-api-reports.mjs",
    "test:changelog": "node tools/check-changelog.mjs",
    "api-report:update": "node tools/check-api-reports.mjs --local",
    "release:dry-run": "pnpm run test:changelog && pnpm run lint && pnpm run test:dead-code && pnpm run test:architecture && pnpm run test:coverage && pnpm run build:lib && pnpm run test:package-pack && pnpm run test:api-report && pnpm run benchmark:style-bundle --skip-build",
    "benchmark:style-bundle": "node tools/check-consumer-fixtures.mjs styles-aggregate",
    "test:consumer-fixtures": "node tools/check-consumer-fixtures.mjs",
    "test:package-pack": "publint dist/hell --pack=false --strict && node tools/check-package-pack.mjs",
    "ci:install": "pnpm install --frozen-lockfile",
    "ci:playwright:chromium": "pnpm exec playwright install --with-deps chromium",
    "ci:test:unit": "pnpm run test:coverage",
    "ci:test:static": "pnpm run lint && pnpm run test:dead-code && pnpm run test:architecture",
    "ci:test:e2e": "pnpm exec playwright test",
    "ci:test:consumer-fixtures": "pnpm run test:consumer-fixtures",
    "ci:build:lib": "pnpm run build:lib",
    "ci:build:docs:prepared": "pnpm run build:docs",
    "ci:check:entrypoints": "node tools/generate-entrypoint-manifests.mjs --check",
    "ci:pack:lib": "pnpm run test:package-pack -- --pack-destination artifacts/package",
    "ci:test:api-report:prepared": "pnpm run test:api-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@eslint/js": "catalog:",
    "@microsoft/api-extractor": "catalog:",
    "@playwright/test": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "angular-eslint": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "publint": "^0.3.21",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "^7.3.5",
    "vitest": "catalog:"
  }
}
