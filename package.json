{
  "name": "hell-ui",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "start": "pnpm --filter hell-docs start",
    "build": "pnpm run build:lib && pnpm run build:docs",
    "build:lib": "pnpm --filter @hell-ui/angular build",
    "build:docs": "pnpm --filter hell-docs build && node tools/docs-bundle-budget-report.mjs --check",
    "diagnose:docs-bundle": "node tools/docs-bundle-budget-report.mjs",
    "watch": "pnpm --filter @hell-ui/angular watch",
    "test:unit": "node tools/run-unit-tests.mjs",
    "test": "pnpm run test:unit && pnpm run test:architecture && pnpm run test:ci-coverage",
    "lint": "eslint .",
    "e2e": "playwright test",
    "generate:entrypoints": "node tools/generate-entrypoint-manifests.mjs",
    "test:architecture": "node tools/check-architecture.mjs",
    "test:api-report": "node tools/check-api-reports.mjs",
    "test:changelog": "node tools/check-changelog.mjs",
    "api-report:update": "node tools/check-api-reports.mjs --local",
    "release:dry-run": "node tools/release-dry-run.mjs",
    "release:dry-run:fast": "node tools/release-dry-run.mjs --fast",
    "test:package-consumer": "node tools/check-package-consumer.mjs",
    "test:package-pack": "node tools/check-package-pack.mjs",
    "test:ci-coverage": "node tools/check-ci-coverage.mjs",
    "ci:install": "pnpm install --frozen-lockfile",
    "ci:playwright:chromium": "pnpm exec playwright install --with-deps chromium",
    "ci:test:unit": "node tools/run-unit-tests.mjs --ci-summary",
    "ci:test:static": "pnpm run lint && pnpm run test:architecture && pnpm run test:ci-coverage",
    "ci:test:e2e": "pnpm exec playwright test",
    "ci:test:package-consumer": "pnpm run test:package-consumer -- --minimal-deps",
    "ci:build:lib": "pnpm run build:lib",
    "ci:build:docs:prepared": "pnpm run build:docs",
    "ci:ensure:build:lib": "sh -c 'test -f dist/hell/package.json || pnpm run ci:build:lib'",
    "ci:ensure:build:docs": "sh -c 'test -f dist/hell-docs/browser/index.html || test -f dist/hell-docs/index.html || pnpm run ci:build:docs:prepared'",
    "ci:test:api-report:prepared": "pnpm run test:api-report",
    "ci:verify": "pnpm run release:dry-run:fast"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@eslint/js": "catalog:",
    "@microsoft/api-extractor": "catalog:",
    "@playwright/test": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "angular-eslint": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
