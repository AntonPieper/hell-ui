{
  "name": "hell-ui",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "start": "pnpm --filter hell-docs start",
    "build": "pnpm run build:lib && pnpm run build:docs",
    "build:lib": "pnpm --filter @hell-ui/angular build && pnpm --filter @hell-ui/pdf-viewer build",
    "build:docs": "pnpm --filter hell-docs build && node tools/docs-bundle-budget-report.mjs --check --summary-only --verify-output",
    "diagnose:docs-bundle": "node tools/docs-bundle-budget-report.mjs",
    "watch": "pnpm --filter @hell-ui/angular watch",
    "test:unit": "node tools/run-unit-tests.mjs",
    "test": "pnpm run test:unit && pnpm run test:architecture && pnpm run test:ci-contract",
    "lint": "eslint .",
    "e2e": "playwright test",
    "generate:entrypoints": "node tools/generate-entrypoint-manifests.mjs",
    "test:architecture": "node tools/check-architecture.mjs",
    "test:api-report": "node tools/check-api-reports.mjs",
    "test:changelog": "node tools/check-changelog.mjs",
    "api-report:update": "node tools/check-api-reports.mjs --local",
    "release:dry-run": "node tools/release-dry-run.mjs",
    "release:dry-run:fast": "node tools/release-dry-run.mjs --fast",
    "release:dry-run:full": "node tools/release-dry-run.mjs --full",
    "production-ready:check": "node tools/production-ready-check.mjs",
    "test:package-consumer": "node tools/check-package-consumer.mjs",
    "test:package-pack": "node tools/check-package-pack.mjs",
    "test:ci-contract": "node tools/check-ci-contract.mjs",
    "ci:install": "pnpm install --frozen-lockfile",
    "ci:test": "node tools/run-ci-tests.mjs",
    "ci:playwright": "pnpm exec playwright install --with-deps chromium firefox webkit",
    "ci:playwright:chromium": "pnpm exec playwright install --with-deps chromium",
    "ci:playwright:firefox": "pnpm exec playwright install --with-deps firefox",
    "ci:playwright:webkit": "pnpm exec playwright install --with-deps webkit",
    "ci:test:unit": "node tools/run-unit-tests.mjs --ci-summary",
    "ci:test:static": "pnpm run lint && pnpm run test:architecture && pnpm run test:ci-contract",
    "ci:test:e2e": "pnpm exec playwright test",
    "ci:test:package-consumer": "pnpm run test:package-consumer -- --minimal-deps",
    "ci:test:package-consumer:core": "HELL_PACKAGE_CONSUMER_SCENARIOS=root-core,core,testing pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:primitives": "HELL_PACKAGE_CONSUMER_SCENARIOS=primitive-icons-css,button-ui,button,pagination pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:composites": "HELL_PACKAGE_CONSUMER_SCENARIOS=composite-css,app-shell,resizable,split-view,audio-player,audio-transcript pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:features": "HELL_PACKAGE_CONSUMER_SCENARIOS=code-editor,pdf-viewer pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:tables": "HELL_PACKAGE_CONSUMER_SCENARIOS=table,table-tanstack,table-tanstack-virtual,no-legacy-alias pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:code-editor": "HELL_PACKAGE_CONSUMER_SCENARIOS=code-editor pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:pdf-viewer": "HELL_PACKAGE_CONSUMER_SCENARIOS=pdf-viewer pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:table-core": "HELL_PACKAGE_CONSUMER_SCENARIOS=table,no-legacy-alias pnpm run ci:test:package-consumer",
    "ci:test:package-consumer:table-adapters": "HELL_PACKAGE_CONSUMER_SCENARIOS=table-tanstack,table-tanstack-virtual pnpm run ci:test:package-consumer",
    "ci:build:lib": "pnpm run build:lib",
    "ci:build:docs": "pnpm run build:lib && pnpm run build:docs",
    "ci:build:docs:prepared": "pnpm run build:docs",
    "ci:ensure:build:lib": "sh -c 'test -f dist/hell/package.json && test -f dist/hell-pdf-viewer/package.json || pnpm run ci:build:lib'",
    "ci:ensure:build:docs": "sh -c 'test -f dist/hell-docs/browser/index.html || test -f dist/hell-docs/index.html || pnpm run ci:build:docs:prepared'",
    "ci:test:api-report": "pnpm run build:lib && pnpm run test:api-report",
    "ci:test:api-report:prepared": "pnpm run test:api-report",
    "ci:build": "pnpm run build:lib && pnpm run build:docs && pnpm run test:api-report",
    "ci:verify": "pnpm run ci:test && pnpm run ci:build"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@eslint/js": "catalog:",
    "@microsoft/api-extractor": "catalog:",
    "@playwright/test": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "angular-eslint": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
