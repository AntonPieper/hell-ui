{
  "name": "hell-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node tools/package-manager.mjs run build:lib && node tools/setup-docs-hell-package-alias.mjs && ng serve",
    "build": "node tools/package-manager.mjs run build:lib && node tools/package-manager.mjs run build:docs",
    "build:lib": "ng build hell",
    "build:docs": "node tools/setup-docs-hell-package-alias.mjs && ng build hell-docs",
    "watch": "ng build hell --watch --configuration development",
    "test:unit": "node tools/run-unit-tests.mjs",
    "test": "node tools/package-manager.mjs run test:unit && node tools/package-manager.mjs run test:architecture && node tools/package-manager.mjs run test:ci-contract",
    "lint": "eslint .",
    "e2e": "playwright test",
    "generate:entrypoints": "node tools/generate-entrypoint-manifests.mjs",
    "test:architecture": "node tools/check-architecture.mjs",
    "test:api-report": "node tools/check-api-reports.mjs",
    "api-report:update": "node tools/check-api-reports.mjs --local",
    "release:dry-run": "node tools/release-dry-run.mjs",
    "release:dry-run:fast": "node tools/release-dry-run.mjs --fast",
    "release:dry-run:full": "node tools/release-dry-run.mjs --full",
    "test:package-consumer": "node tools/check-package-consumer.mjs",
    "test:package-pack": "node tools/check-package-pack.mjs",
    "test:ci-contract": "node tools/check-ci-contract.mjs",
    "ci:install": "node tools/package-manager.mjs install",
    "ci:test": "node tools/run-ci-tests.mjs",
    "ci:playwright": "node tools/package-manager.mjs exec playwright install --with-deps chromium firefox webkit",
    "ci:build": "node tools/package-manager.mjs run build && node tools/package-manager.mjs run test:api-report",
    "ci:verify": "node tools/package-manager.mjs run ci:test && node tools/package-manager.mjs run ci:build"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "dependencies": {
    "@angular/cdk": "^21.2.11",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-angular": "^0.1.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@floating-ui/dom": "^1.7.6",
    "@lezer/highlight": "^1.2.3",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/font-awesome": "^33.2.2",
    "class-variance-authority": "^0.7.1",
    "ng-primitives": "0.117.2",
    "pdfjs-dist": "5.6.205",
    "rxjs": "~7.8.2",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@axe-core/playwright": "^4.11.3",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@vitest/coverage-v8": "4.1.5",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.3.0",
    "jsdom": "^29.0.2",
    "ng-packagr": "^21.2.3",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "4.1.5"
  }
}
