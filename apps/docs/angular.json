{
  "$schema": "../../node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false
  },
  "projects": {
    "hell-docs": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": ".",
      "sourceRoot": "src",
      "prefix": "hd",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "outputPath": "../../dist/hell-docs",
            "tsConfig": "tsconfig.app.json",
            "conditions": ["@heinrich/source", "module"],
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "node_modules/hell-ui/assets",
                "output": "assets"
              },
              {
                "glob": "pdf.worker.mjs",
                "input": "node_modules/pdfjs-dist/build",
                "output": "assets"
              },
              {
                "glob": "styles.css",
                "input": "node_modules/hell-ui/features/pdf-viewer",
                "output": "hell-ui/pdf-viewer/styles"
              },
              {
                "glob": "*.css",
                "input": "node_modules/hell-ui/themes",
                "output": "hell-ui/themes"
              },
              {
                "glob": "pdf_viewer.css",
                "input": "node_modules/pdfjs-dist/web",
                "output": "pdfjs"
              },
              {
                "glob": "**/*",
                "input": "node_modules/pdfjs-dist/web/images",
                "output": "pdfjs/images"
              }
            ],
            "styles": [
              "src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "conditions": ["@heinrich/source", "module", "production"],
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false,
                  "removeSpecialComments": true
                },
                "fonts": {
                  "inline": true
                }
              },
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "950kB",
                  "maximumError": "1.05MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "conditions": ["@heinrich/source", "module", "development"],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "prebundle": {
              "exclude": ["hell-ui"]
            }
          },
          "configurations": {
            "production": {
              "buildTarget": "hell-docs:build:production"
            },
            "development": {
              "buildTarget": "hell-docs:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
