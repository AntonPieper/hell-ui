{
  "name": "@hell-ui/pdf-viewer",
  "version": "0.1.0",
  "description": "Hell UI PDF viewer package for Angular, backed by pdf.js.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntonPieper/hell-ui.git",
    "directory": "projects/hell-pdf-viewer"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "files": [
    "README.md",
    "package.json",
    "fesm2022/*.mjs",
    "types/*.d.ts",
    "styles/**/*.css"
  ],
  "exports": {
    "./styles": {
      "style": "./styles/pdf-viewer.css",
      "default": "./styles/pdf-viewer.css"
    },
    "./styles/pdf-viewer": {
      "style": "./styles/pdf-viewer.css",
      "default": "./styles/pdf-viewer.css"
    },
    "./styles/components/pdf-viewer": {
      "style": "./styles/components/pdf-viewer.css",
      "default": "./styles/components/pdf-viewer.css"
    }
  },
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@hell-ui/angular": "0.1.0",
    "@ng-icons/core": "^33.0.0",
    "@ng-icons/font-awesome": "^33.0.0",
    "pdfjs-dist": "5.6.205",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
