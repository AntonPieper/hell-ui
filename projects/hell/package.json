{
  "name": "@hell-ui/angular",
  "version": "0.1.0",
  "description": "Heinrich Element Library — opinionated Angular component set built on ng-primitives + Tailwind v4.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntonPieper/hell-ui.git",
    "directory": "projects/hell"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "files": [
    "README.md",
    "package.json",
    "**/package.json",
    "fesm2022/*.mjs",
    "types/*.d.ts",
    "styles/**/*.css",
    "assets/**"
  ],
  "exports": {
    "./styles": {
      "style": "./styles/hell.css",
      "default": "./styles/hell.css"
    },
    "./styles/tokens": {
      "style": "./styles/tokens.css",
      "default": "./styles/tokens.css"
    },
    "./styles/primitives": {
      "style": "./styles/primitives.css",
      "default": "./styles/primitives.css"
    },
    "./styles/composites": {
      "style": "./styles/composites.css",
      "default": "./styles/composites.css"
    },
    "./styles/table": {
      "style": "./styles/table.css",
      "default": "./styles/table.css"
    },
    "./styles/features/code-editor": {
      "style": "./styles/features/code-editor.css",
      "default": "./styles/features/code-editor.css"
    },
    "./styles/kitchen-sink": {
      "style": "./styles/hell.css",
      "default": "./styles/hell.css"
    },
    "./styles/components/*": {
      "style": "./styles/components/*.css",
      "default": "./styles/components/*.css"
    }
  },
  "peerDependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@floating-ui/dom": "^1.7.6",
    "@tanstack/angular-table": "^8.21.4",
    "ng-primitives": "0.117.2",
    "@ng-icons/core": "^33.0.0",
    "@ng-icons/font-awesome": "^33.0.0",
    "rxjs": "^7.8.0",
    "tailwindcss": "^4.0.0",
    "@codemirror/view": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@lezer/highlight": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    },
    "@angular/router": {
      "optional": true
    },
    "@ng-icons/font-awesome": {
      "optional": true
    },
    "@tanstack/angular-table": {
      "optional": true
    },
    "@codemirror/commands": {
      "optional": true
    },
    "@codemirror/language": {
      "optional": true
    },
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    },
    "@lezer/highlight": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
