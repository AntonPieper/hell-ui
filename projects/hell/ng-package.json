{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/hell",
  "assets": [
    {
      "glob": "**/*.css",
      "input": "src/lib/styles",
      "output": "styles"
    },
    {
      "glob": "**/*",
      "input": "assets",
      "output": "assets"
    }
  ],
  "lib": {
    "entryFile": "src/public-api.ts"
  }
}
