/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/app",
    "types": [],
    "moduleResolution": "bundler",
    "paths": {
      "@hell-ui/angular": ["../../dist/hell/types/hell-ui-angular.d.ts"],
      "@hell-ui/angular/styles": ["../../dist/hell/styles/hell.css"],
      "@hell-ui/angular/styles/*": ["../../dist/hell/styles/*"],
      "@hell-ui/angular/core": ["../../dist/hell/types/hell-ui-angular-core.d.ts"],
      "@hell-ui/angular/primitives": ["../../dist/hell/types/hell-ui-angular-primitives.d.ts"],
      "@hell-ui/angular/composites": ["../../dist/hell/types/hell-ui-angular-composites.d.ts"],
      "@hell-ui/angular/features/code-editor": ["../../dist/hell/types/hell-ui-angular-features-code-editor.d.ts"],
      "@hell-ui/angular/table": ["../../dist/hell/types/hell-ui-angular-table.d.ts"],
      "@hell-ui/angular/table-tanstack": ["../../dist/hell/types/hell-ui-angular-table-tanstack.d.ts"],
      "@hell-ui/angular/table-tanstack/virtual": ["../../dist/hell/types/hell-ui-angular-table-tanstack-virtual.d.ts"],
      "@hell-ui/pdf-viewer": ["../../dist/hell-pdf-viewer/types/hell-ui-pdf-viewer.d.ts"],
      "@hell-ui/pdf-viewer/styles": ["../../dist/hell-pdf-viewer/styles/pdf-viewer.css"],
      "@hell-ui/pdf-viewer/styles/*": ["../../dist/hell-pdf-viewer/styles/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
