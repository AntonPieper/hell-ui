      "@hell-ui/angular/features/data-table": ["../../dist/hell/types/hell-ui-angular-features-data-table.d.ts"],
      "@hell-ui/angular/features/table-utilities": ["../../dist/hell/types/hell-ui-angular-features-table-utilities.d.ts"],
      "@hell-ui/angular/features/pdf-viewer": ["../../dist/hell/types/hell-ui-angular-features-pdf-viewer.d.ts"]
