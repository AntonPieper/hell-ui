{
  "name": "@hell-ui/pdf-viewer",
  "version": "0.1.0",
  "description": "Hell UI PDF viewer package for Angular, backed by pdf.js.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntonPieper/hell-ui.git",
    "directory": "packages/pdf-viewer"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "files": [
    "README.md",
    "package.json",
    "fesm2022/*.mjs",
    "types/*.d.ts",
    "pdf-viewer/**/*.css"
  ],
  "exports": {
    "./styles": {
      "@heinrich/source": "./src/lib/pdf-viewer/pdf-viewer.css",
      "style": "./src/lib/pdf-viewer/pdf-viewer.css",
      "default": "./src/lib/pdf-viewer/pdf-viewer.css"
    },
    "./styles/pdf-viewer": {
      "@heinrich/source": "./src/lib/pdf-viewer/pdf-viewer.css",
      "style": "./src/lib/pdf-viewer/pdf-viewer.css",
      "default": "./src/lib/pdf-viewer/pdf-viewer.css"
    },
    ".": {
      "@heinrich/source": "./src/public-api.ts"
    }
  },
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@hell-ui/angular": "0.1.0",
    "@ng-icons/core": "^33.0.0",
    "@ng-icons/font-awesome": "^33.0.0",
    "pdfjs-dist": "5.6.205",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "tslib": "catalog:"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "ng build hell-pdf-viewer && node ../../tools/finalize-dist-package.mjs ../../dist/hell-pdf-viewer",
    "build:development": "ng build hell-pdf-viewer --configuration development && node ../../tools/finalize-dist-package.mjs ../../dist/hell-pdf-viewer",
    "watch": "ng build hell-pdf-viewer --watch --configuration development",
    "test": "ng test hell-pdf-viewer"
  },
  "devDependencies": {
    "@hell-ui/angular": "workspace:*",
    "@angular/build": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@ng-icons/core": "catalog:",
    "@ng-icons/font-awesome": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "ng-packagr": "catalog:",
    "ng-primitives": "catalog:",
    "pdfjs-dist": "catalog:",
    "rxjs": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
