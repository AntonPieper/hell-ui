/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec/hell-pdf-viewer",
    "types": [
      "vitest/globals"
    ],
    "customConditions": [],
    "paths": {
      "@hell-ui/angular": [
        "../../dist/hell/types/hell-ui-angular.d.ts"
      ],
      "@hell-ui/angular/*": [
        "../../dist/hell/*",
        "../../dist/hell/types/hell-ui-angular-*.d.ts"
      ],
      /* The dist type declarations above import ng-primitives; resolve it
         from this package's own dependencies so host-directive inputs
         (e.g. HellPagination page/pageCount) keep their types. */
      "ng-primitives/*": [
        "./node_modules/ng-primitives/types/ng-primitives-*.d.ts",
        "./node_modules/ng-primitives/*"
      ]
    }
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.spec.ts"
  ]
}
