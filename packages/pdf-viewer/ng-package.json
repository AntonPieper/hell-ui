{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/hell-pdf-viewer",
  "assets": [
    {
      "glob": "LICENSE",
      "input": ".",
      "output": "."
    },
    {
      "glob": "**/*.css",
