{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec",
    "paths": {
      "@hell-ui/angular": [
        "./public-api.ts"
      ],
      "@hell-ui/angular/*": [
        "./*/public-api.ts"
      ]
    },
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "**/*.d.ts",
    "**/*.spec.ts"
  ],
  "exclude": [
    "node_modules/**"
  ]
}
