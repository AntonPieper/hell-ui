{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/hell",
  "allowedNonPeerDependencies": [
    "tailwind-merge"
  ],
  "assets": [
    {
      "glob": "tokens.css",
      "input": ".",
      "output": "."
    },
    {
      "glob": "*/styles.css",
      "input": ".",
      "output": "."
    },
    {
      "glob": "features/*/styles.css",
      "input": ".",
      "output": "."
    },
    {
      "glob": "internal/*/styles.css",
      "input": ".",
      "output": "."
    },
    {
      "glob": "button.ts",
      "input": "button",
      "output": "button"
    },
    {
      "glob": "input.ts",
      "input": "input",
      "output": "input"
    },
    {
      "glob": "dialpad.ts",
      "input": "dialpad",
      "output": "dialpad"
    },
    {
      "glob": "date-input.ts",
      "input": "date-input",
      "output": "date-input"
    },
    {
      "glob": "date-picker.ts",
      "input": "date-picker",
      "output": "date-picker"
    },
    {
      "glob": "time-input.ts",
      "input": "time-input",
      "output": "time-input"
    },
    {
      "glob": "hell-ui-logo.svg",
      "input": "assets",
      "output": "assets"
    }
  ],
  "lib": {
    "entryFile": "public-api.ts"
  }
}
