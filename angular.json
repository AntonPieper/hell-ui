{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "hell": {
      "projectType": "library",
      "root": "projects/hell",
      "sourceRoot": "projects/hell/src",
      "prefix": "hell",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/hell/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/hell/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/hell/tsconfig.spec.json"
          }
        }
      }
    },
    "hell-docs": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/hell-docs",
      "sourceRoot": "projects/hell-docs/src",
      "prefix": "hd",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/hell-docs/src/main.ts",
            "tsConfig": "projects/hell-docs/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/hell-docs/public"
              },
              {
                "glob": "**/*",
                "input": "projects/hell/assets",
                "output": "assets"
              },
              {
                "glob": "pdf-viewer.css",
                "input": "dist/hell/styles/features",
                "output": "hell-ui/styles/features"
              },
              {
                "glob": "pdf-viewer.css",
                "input": "dist/hell/styles/components",
                "output": "hell-ui/styles/components"
              },
              {
                "glob": "pdf_viewer.css",
                "input": "node_modules/pdfjs-dist/web",
                "output": "pdfjs"
              },
              {
                "glob": "**/*",
                "input": "node_modules/pdfjs-dist/web/images",
                "output": "pdfjs/images"
              }
            ],
            "styles": [
              "projects/hell-docs/src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1.05MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "statsJson": true
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "hell-docs:build:production"
            },
            "development": {
              "buildTarget": "hell-docs:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
